@model DashboardMetricDetailsDto
@using Microsoft.AspNetCore.Routing

@{
    var excelRoute = new RouteValueDictionary
    {
        ["view"] = Model.View,
        ["format"] = DashboardExportFormat.Excel
    };
    var pdfRoute = new RouteValueDictionary
    {
        ["view"] = Model.View,
        ["format"] = DashboardExportFormat.Pdf
    };
    var previousRoute = new RouteValueDictionary
    {
        ["view"] = Model.View,
        ["page"] = Model.Page - 1,
        ["pageSize"] = Model.PageSize
    };
    var nextRoute = new RouteValueDictionary
    {
        ["view"] = Model.View,
        ["page"] = Model.Page + 1,
        ["pageSize"] = Model.PageSize
    };

    if (Model.Chart.HasValue)
    {
        excelRoute["chart"] = Model.Chart.Value;
        excelRoute["segmentKey"] = Model.SegmentKey;
        pdfRoute["chart"] = Model.Chart.Value;
        pdfRoute["segmentKey"] = Model.SegmentKey;
        previousRoute["chart"] = Model.Chart.Value;
        previousRoute["segmentKey"] = Model.SegmentKey;
        nextRoute["chart"] = Model.Chart.Value;
        nextRoute["segmentKey"] = Model.SegmentKey;
    }
    else
    {
        excelRoute["metric"] = Model.Metric;
        pdfRoute["metric"] = Model.Metric;
        previousRoute["metric"] = Model.Metric;
        nextRoute["metric"] = Model.Metric;
    }
}

<div class="kpi-detail-header">
    <div>
        <span class="eyebrow">Composition de l'indicateur</span>
        <h2 class="h5 mb-1">@Model.Title</h2>
        <p>@Model.Definition</p>
    </div>
    <div class="kpi-detail-actions">
        <div class="kpi-detail-total">
            <strong>@Model.TotalCount</strong>
            <span>element(s)</span>
        </div>
        <div class="kpi-export-actions" aria-label="Exporter les details">
            <a class="btn btn-sm btn-outline-primary"
               href="@Url.Action(Model.ExportAction, "Home", excelRoute)">
                <svg class="icon"><use href="#icon-download"></use></svg>Excel
            </a>
            <a class="btn btn-sm btn-outline-primary"
               href="@Url.Action(Model.ExportAction, "Home", pdfRoute)">
                <svg class="icon"><use href="#icon-download"></use></svg>PDF
            </a>
        </div>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="kpi-detail-empty">
        <svg class="icon icon-lg"><use href="#icon-check"></use></svg>
        <strong>Aucun element a traiter</strong>
        <span>Le perimetre actuel ne contient aucune anomalie pour cet indicateur.</span>
    </div>
}
else
{
    <div class="table-responsive kpi-detail-table">
        <table class="table table-sm align-middle">
            <thead>
            <tr>
                <th>Taxe</th>
                <th>Periode</th>
                <th>Echeance</th>
                <th>Statut</th>
                <th>Risque</th>
                <th>Responsable</th>
                <th>Decision attendue</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                var issueClass = item.DaysLate > 0 ? "status-danger" :
                    item.RiskLevel is EthanTcm.Domain.Enums.RiskLevel.High or EthanTcm.Domain.Enums.RiskLevel.Critical
                        ? "status-warning"
                        : "status-active";
                <tr>
                    <td><strong>@item.Name</strong></td>
                    <td>@(item.PeriodLabel ?? "-")</td>
                    <td>
                        @(item.DueDate?.ToString("dd/MM/yyyy") ?? "-")
                        @if (item.DaysLate > 0)
                        {
                            <small class="d-block text-danger">@item.DaysLate jour(s) de retard</small>
                        }
                    </td>
                    <td>@item.Status</td>
                    <td>@item.RiskLevel</td>
                    <td>@(item.AssignedTo ?? "Non attribue")</td>
                    <td><span class="status-pill @issueClass">@item.Issue</span></td>
                    <td class="text-end">
                        @if (item.TargetType == DashboardDetailTargetType.TaxDeclaration)
                        {
                            <a class="btn btn-sm btn-outline-primary"
                               asp-controller="TaxDeclarations"
                               asp-action="Details"
                               asp-route-id="@item.Id">Ouvrir</a>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-primary"
                               asp-controller="TaxObligations"
                               asp-action="Details"
                               asp-route-id="@item.Id">Ouvrir</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<div class="kpi-detail-footer">
    <span>Page @Model.Page sur @Model.TotalPages</span>
    <div class="data-table-pagination">
        <a class="btn btn-outline-secondary btn-sm js-kpi-page @(Model.Page <= 1 ? "disabled" : null)"
           href="@Url.Action(Model.DetailAction, "Home", previousRoute)">Precedent</a>
        <a class="btn btn-outline-secondary btn-sm js-kpi-page @(Model.Page >= Model.TotalPages ? "disabled" : null)"
           href="@Url.Action(Model.DetailAction, "Home", nextRoute)">Suivant</a>
    </div>
</div>
