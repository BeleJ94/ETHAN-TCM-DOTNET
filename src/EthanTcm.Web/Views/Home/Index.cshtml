@using EthanTcm.Domain.Enums
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var dashboard = Model.Dashboard;
    var metrics = dashboard.Metrics;
    var charts = dashboard.Charts;
    var chartPayload = new
    {
        detailBaseUrl = Url.Action("ChartDetails", "Home", new { view = dashboard.ActiveView }),
        dueDateBuckets = charts.DueDateBuckets,
        statusDistribution = charts.StatusDistribution,
        riskDistribution = charts.RiskDistribution,
        ownerWorkload = charts.OwnerWorkload
    };
    var chartPayloadJson = JsonSerializer.Serialize(chartPayload, new JsonSerializerOptions(JsonSerializerDefaults.Web));
    var canGenerateDeclarations = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.GenerateTaxDeclarations)).Succeeded;
    var canCreateDeclarations = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.CreateTaxDeclarations)).Succeeded;
    var dueTodayUrgencyClass = metrics.DueToday > 0 ? " metric-danger" : string.Empty;
    var dueSoonUrgencyClass = metrics.DueInLessThanFiveDays > 0 ? " metric-warning" : string.Empty;
    var lateUrgencyClass = metrics.Late > 0 ? " metric-danger" : string.Empty;
    var penaltyRiskUrgencyClass = metrics.PenaltyRisk > 0 ? " metric-warning" : string.Empty;
    var activeViewLabel = dashboard.ActiveView switch
    {
        DashboardView.MyTasks => "Mes tâches",
        DashboardView.TeamTasks => "Tâches de l’équipe",
        DashboardView.ManagementOverview => "Supervision",
        DashboardView.LateItems => "Éléments en retard",
        DashboardView.ComplianceOverview => "Conformité",
        _ => dashboard.ActiveView.ToString()
    };
    var activeViewDescription = dashboard.ActiveView switch
    {
        DashboardView.MyTasks => "Déclarations qui nécessitent une action de votre part.",
        DashboardView.TeamTasks => "Charge ouverte visible dans votre périmètre opérationnel.",
        DashboardView.ManagementOverview => "Vue de supervision avec les déclarations ouvertes et les anomalies de responsabilité.",
        DashboardView.LateItems => "Déclarations dont l’échéance est dépassée et qui demandent une action rapide.",
        DashboardView.ComplianceOverview => "Dossiers présentant un risque de conformité ou une preuve réglementaire manquante.",
        _ => "Vue filtrée du tableau de bord."
    };
}

<section class="page-shell dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Pilotage fiscal</span>
            <h1>Tableau de bord décisionnel</h1>
            <p>Priorisez les échéances, validations, paiements et anomalies de conformité.</p>
        </div>
        @if (canGenerateDeclarations || canCreateDeclarations)
        {
            <div class="form-actions">
                @if (canGenerateDeclarations)
                {
                    <a class="btn btn-outline-primary" asp-controller="TaxDeclarations" asp-action="Generate"><svg class="icon"><use href="#icon-plus"></use></svg>Générer</a>
                }
                @if (canCreateDeclarations)
                {
                    <a class="btn btn-outline-secondary" asp-controller="TaxDeclarations" asp-action="Manual"><svg class="icon"><use href="#icon-edit"></use></svg>Créer manuellement</a>
                }
            </div>
        }
    </div>

    <nav class="dashboard-tabs" aria-label="Dashboard views">
        <a class="dashboard-tab @(dashboard.ActiveView == DashboardView.MyTasks ? "dashboard-tab-active" : string.Empty)" asp-action="Index" asp-route-view="@DashboardView.MyTasks">
            <span>Mes tâches</span>
            <small>À traiter par moi</small>
        </a>
        <a class="dashboard-tab @(dashboard.ActiveView == DashboardView.TeamTasks ? "dashboard-tab-active" : string.Empty)" asp-action="Index" asp-route-view="@DashboardView.TeamTasks">
            <span>Équipe</span>
            <small>Charge ouverte</small>
        </a>
        <a class="dashboard-tab @(dashboard.ActiveView == DashboardView.ManagementOverview ? "dashboard-tab-active" : string.Empty)" asp-action="Index" asp-route-view="@DashboardView.ManagementOverview">
            <span>Supervision</span>
            <small>Vue globale</small>
        </a>
        <a class="dashboard-tab @(dashboard.ActiveView == DashboardView.LateItems ? "dashboard-tab-active" : string.Empty)" asp-action="Index" asp-route-view="@DashboardView.LateItems">
            <span>Retards</span>
            <small>Échéances dépassées</small>
        </a>
        <a class="dashboard-tab @(dashboard.ActiveView == DashboardView.ComplianceOverview ? "dashboard-tab-active" : string.Empty)" asp-action="Index" asp-route-view="@DashboardView.ComplianceOverview">
            <span>Conformité</span>
            <small>Risques et preuves</small>
        </a>
    </nav>

    <section class="dashboard-view-note" aria-label="Filtre actif">
        <span>Filtre actif</span>
        <strong>@activeViewLabel</strong>
        <p>@activeViewDescription</p>
    </section>

    <section class="dashboard-context-strip" aria-label="Contexte du tableau de bord">
        <div>
            <span>Vue active</span>
            <strong>@activeViewLabel</strong>
        </div>
        <div>
            <span>Déclarations ouvertes</span>
            <strong>@metrics.OpenDeclarations</strong>
        </div>
        <div>
            <span>Couverture des preuves</span>
            <strong>@metrics.EvidenceComplianceRate.ToString("0.0") %</strong>
        </div>
        <div>
            <span>Dernière actualisation</span>
            <strong>@dashboard.GeneratedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
        </div>
    </section>

    <section class="dashboard-analytics" aria-labelledby="dashboard-analytics-title">
        <div class="dashboard-kpi-heading">
            <div>
                <span class="eyebrow">Vue analytique</span>
                <h2 id="dashboard-analytics-title">Lecture rapide de la charge</h2>
            </div>
            <p>Reperez les blocages par echeance, statut, niveau de risque et responsable.</p>
        </div>
        <div class="dashboard-analytics-grid">
            <article class="analytics-panel analytics-panel-wide">
                <div class="analytics-panel-header">
                    <div>
                        <h3>Charge par echeance</h3>
                        <p>Histogramme des actions selon leur urgence.</p>
                    </div>
                    <strong>@metrics.OpenDeclarations</strong>
                </div>
                <div class="analytics-chart-frame analytics-chart-frame-wide">
                    <canvas id="dueDateChart" aria-label="Charge par echeance" role="img"></canvas>
                </div>
                <div class="analytics-legend">
                    @foreach (var point in charts.DueDateBuckets)
                    {
                        <span class="analytics-legend-item analytics-tone-@point.Tone"><i></i>@point.Label <strong>@point.Value</strong></span>
                    }
                </div>
            </article>

            <article class="analytics-panel">
                <div class="analytics-panel-header">
                    <div>
                        <h3>Statuts</h3>
                        <p>Donut du workflow ouvert.</p>
                    </div>
                </div>
                <div class="analytics-chart-frame analytics-chart-frame-donut">
                    <canvas id="statusChart" aria-label="Repartition par statut" role="img"></canvas>
                </div>
                <div class="analytics-legend analytics-legend-compact">
                    @foreach (var point in charts.StatusDistribution)
                    {
                        <span class="analytics-legend-item analytics-tone-@point.Tone"><i></i>@point.Label <strong>@point.Value</strong></span>
                    }
                </div>
            </article>

            <article class="analytics-panel">
                <div class="analytics-panel-header">
                    <div>
                        <h3>Risques</h3>
                        <p>Donut de criticite fiscale.</p>
                    </div>
                </div>
                <div class="analytics-chart-frame analytics-chart-frame-donut">
                    <canvas id="riskChart" aria-label="Repartition par risque" role="img"></canvas>
                </div>
                <div class="analytics-legend analytics-legend-compact">
                    @foreach (var point in charts.RiskDistribution)
                    {
                        <span class="analytics-legend-item analytics-tone-@point.Tone"><i></i>@point.Label <strong>@point.Value</strong></span>
                    }
                </div>
            </article>

            <article class="analytics-panel">
                <div class="analytics-panel-header">
                    <div>
                        <h3>Top responsables</h3>
                        <p>Bar chart des owners les plus charges.</p>
                    </div>
                </div>
                <div class="analytics-chart-frame">
                    <canvas id="ownerChart" aria-label="Charge par responsable" role="img"></canvas>
                </div>
                <div class="analytics-legend analytics-legend-compact">
                    @foreach (var point in charts.OwnerWorkload)
                    {
                        <span class="analytics-legend-item analytics-tone-@point.Tone"><i></i>@point.Label <strong>@point.Value</strong></span>
                    }
                </div>
            </article>
        </div>
    </section>

    <section class="dashboard-kpi-group" aria-labelledby="priority-kpis">
        <div class="dashboard-kpi-heading">
            <div>
                <span class="eyebrow">Décisions immédiates</span>
                <h2 id="priority-kpis">Priorités opérationnelles</h2>
            </div>
            <p>Commencez par les situations qui nécessitent une action aujourd’hui.</p>
        </div>
        <div class="dashboard-metrics dashboard-metrics-priority">
            <a class="metric metric-link js-kpi-card@(lateUrgencyClass)"
               asp-action="Index" asp-route-view="@DashboardView.LateItems"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.Late })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-alert"></use></svg></span>
                <span>Déclarations en retard</span>
                <strong>@metrics.Late</strong>
                <small>Échéance dépassée, action requise</small>
            </a>
            <a class="metric metric-link js-kpi-card@(dueTodayUrgencyClass)"
               asp-action="Index" asp-route-view="@DashboardView.TeamTasks"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.DueToday })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-calendar"></use></svg></span>
                <span>Échéances du jour</span>
                <strong>@metrics.DueToday</strong>
                <small>À finaliser avant la fin de journée</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-action="Index" asp-route-view="@DashboardView.TeamTasks"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.AwaitingApproval })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-check"></use></svg></span>
                <span>Validations en attente</span>
                <strong>@metrics.AwaitingApproval</strong>
                <small>Décisions bloquant la progression</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-controller="Payments" asp-action="Pending"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.PendingPayments })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-credit-card"></use></svg></span>
                <span>Paiements en attente</span>
                <strong>@metrics.PendingPayments</strong>
                <small>Décaissements à sécuriser</small>
            </a>
        </div>
    </section>

    <section class="dashboard-kpi-group" aria-labelledby="compliance-kpis">
        <div class="dashboard-kpi-heading">
            <div>
                <span class="eyebrow">Maîtrise du risque</span>
                <h2 id="compliance-kpis">Conformité et exposition</h2>
            </div>
            <p>Identifiez les dossiers susceptibles de générer une anomalie ou une pénalité.</p>
        </div>
        <div class="dashboard-metrics">
            <a class="metric metric-link js-kpi-card@(penaltyRiskUrgencyClass)"
               asp-action="Index" asp-route-view="@DashboardView.ComplianceOverview"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.PenaltyRisk })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-alert"></use></svg></span>
                <span>Exposition aux pénalités</span>
                <strong>@metrics.PenaltyRisk</strong>
                <small>Retards, risque élevé ou preuve manquante</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-action="Index" asp-route-view="@DashboardView.ComplianceOverview"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.MissingSubmissionProof })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-paperclip"></use></svg></span>
                <span>Preuves de dépôt manquantes</span>
                <strong>@metrics.MissingSubmissionProof</strong>
                <small>Dépôts non documentés</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-controller="Payments" asp-action="MissingProof"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.MissingPaymentProof })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-credit-card"></use></svg></span>
                <span>Preuves de paiement manquantes</span>
                <strong>@metrics.MissingPaymentProof</strong>
                <small>Paiements sans justificatif actif</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-controller="TaxObligations" asp-action="Index"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.ObligationsWithoutResponsible })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-user"></use></svg></span>
                <span>Taxes sans responsable</span>
                <strong>@metrics.ObligationsWithoutResponsible</strong>
                <small>Risque de rupture de responsabilité</small>
            </a>
        </div>
    </section>

    <section class="dashboard-kpi-group" aria-labelledby="planning-kpis">
        <div class="dashboard-kpi-heading">
            <div>
                <span class="eyebrow">Anticipation</span>
                <h2 id="planning-kpis">Charge à venir</h2>
            </div>
            <p>Visualisez la pression fiscale des prochains jours et du mois.</p>
        </div>
        <div class="dashboard-metrics dashboard-metrics-planning">
            <a class="metric metric-link js-kpi-card@(dueSoonUrgencyClass)"
               asp-action="Index" asp-route-view="@DashboardView.TeamTasks"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.DueSoon })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-clock"></use></svg></span>
                <span>Échéances sous 5 jours</span>
                <strong>@metrics.DueInLessThanFiveDays</strong>
                <small>Hors échéances du jour</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-action="Index" asp-route-view="@DashboardView.TeamTasks"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.DueThisWeek })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-clock"></use></svg></span>
                <span>Échéances de la semaine</span>
                <strong>@metrics.DueThisWeek</strong>
                <small>Charge de la semaine civile</small>
            </a>
            <a class="metric metric-link js-kpi-card"
               asp-action="Index" asp-route-view="@DashboardView.TeamTasks"
               data-kpi-url="@Url.Action("KpiDetails", "Home", new { view = dashboard.ActiveView, metric = DashboardMetric.DueThisMonth })"
               aria-haspopup="dialog">
                <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-calendar"></use></svg></span>
                <span>Échéances du mois</span>
                <strong>@metrics.DueThisMonth</strong>
                <small>Charge du mois civil</small>
            </a>
        </div>
    </section>

    <section class="panel">
        <div class="panel-title-row">
            <div>
                <h2>@activeViewLabel</h2>
                <p class="panel-subtitle">File opérationnelle priorisée par risque et échéance.</p>
            </div>
            <span class="panel-subtitle">@dashboard.Today.ToString("dd/MM/yyyy")</span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle dashboard-table js-data-table" data-page-size="10">
                <thead>
                <tr>
                    <th>Taxe</th>
                    <th>Période</th>
                    <th>Échéance</th>
                    <th>Statut</th>
                    <th>Décision attendue</th>
                    <th>Risque</th>
                    <th>Responsable</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @if (!dashboard.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-muted">Aucun élément ouvert dans ce périmètre.</td>
                    </tr>
                }
                @foreach (var item in dashboard.Items)
                {
                    var statusClass = item.Issue == "En retard" ? "status-danger" :
                        item.RiskLevel is RiskLevel.High or RiskLevel.Critical ? "status-warning" :
                        "status-active";
                    <tr>
                        <td>@item.ObligationName</td>
                        <td>@item.PeriodLabel</td>
                        <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.Status</td>
                        <td>
                            <span class="status-pill @statusClass">@item.Issue</span>
                            @if (item.DaysLate > 0)
                            {
                                <span class="text-muted ms-1">@item.DaysLate d</span>
                            }
                        </td>
                        <td>@item.RiskLevel</td>
                        <td>@item.AssignedTo</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="TaxDeclarations" asp-action="Details" asp-route-id="@item.Id"><svg class="icon"><use href="#icon-open"></use></svg>Ouvrir</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    @if (dashboard.ObligationIssues.Any())
    {
        <section class="panel">
            <div class="panel-title-row">
                <h2>Anomalies du référentiel</h2>
                <span class="panel-subtitle">Qualité des responsabilités</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle js-data-table" data-page-size="10">
                    <thead>
                    <tr>
                        <th>Taxe</th>
                        <th>Risque</th>
                        <th>Anomalie</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in dashboard.ObligationIssues)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.RiskLevel</td>
                            <td><span class="status-pill status-warning">@item.Issue</span></td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="TaxObligations" asp-action="Details" asp-route-id="@item.Id"><svg class="icon"><use href="#icon-open"></use></svg>Ouvrir</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

<div class="modal fade"
     id="dashboard-kpi-modal"
     tabindex="-1"
     aria-labelledby="dashboard-kpi-modal-title"
     aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content kpi-modal-content">
            <div class="modal-header">
                <div>
                    <span class="eyebrow">Analyse détaillée</span>
                    <h2 class="modal-title fs-5" id="dashboard-kpi-modal-title">Détail du KPI</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body js-kpi-modal-body" aria-live="polite">
                <div class="kpi-modal-loading">
                    <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                    <span>Chargement du détail…</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script id="dashboard-chart-data" type="application/json">@Html.Raw(chartPayloadJson)</script>
    <script src="~/js/dashboard-charts.js" asp-append-version="true"></script>
}
