@model TaxMatrixImportViewModel

@{
    ViewData["Title"] = "Tax Matrix Import";
}

<section class="page-shell">
    <div class="page-heading">
        <div>
            <h1>Tax Matrix Import</h1>
            <p>Upload the existing fiscal matrix, review validation errors, then confirm the import.</p>
        </div>
    </div>

    <section class="panel">
        <h2>Upload</h2>
        <form asp-action="Preview" method="post" enctype="multipart/form-data" class="upload-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input class="form-control" type="file" name="file" accept=".xlsx" />
            <button class="btn btn-primary" type="submit"><svg class="icon"><use href="#icon-upload"></use></svg>Preview file</button>
        </form>
    </section>

    @if (Model.HasPreview)
    {
        <section class="panel">
            <h2>Preview</h2>
            <div class="metric-grid">
                <section class="metric">
                    <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-file"></use></svg></span>
                    <span>File</span>
                    <strong>@Model.FileName</strong>
                </section>
                <section class="metric">
                    <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-database"></use></svg></span>
                    <span>Total rows</span>
                    <strong>@Model.TotalRows</strong>
                </section>
                <section class="metric">
                    <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-check"></use></svg></span>
                    <span>Valid rows</span>
                    <strong>@Model.ValidRows</strong>
                </section>
                <section class="metric">
                    <span class="metric-icon"><svg class="icon icon-lg"><use href="#icon-alert"></use></svg></span>
                    <span>Errors</span>
                    <strong>@Model.InvalidRows</strong>
                </section>
            </div>

            @if (Model.Errors.Count > 0)
            {
                <div class="table-responsive mt-3">
                    <table class="table table-sm align-middle js-data-table" data-page-size="10">
                        <thead>
                        <tr>
                            <th>Row</th>
                            <th>Column</th>
                            <th>Error</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var error in Model.Errors)
                        {
                            <tr>
                                <td>@error.RowNumber</td>
                                <td>@error.ColumnName</td>
                                <td>@error.Message</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

            @if (Model.CanImport)
            {
                <form asp-action="Commit" method="post" class="mt-3">
                    <input type="hidden" name="importBatchId" value="@Model.ImportBatchId" />
                    <button class="btn btn-success" type="submit"><svg class="icon"><use href="#icon-check"></use></svg>Confirm import</button>
                </form>
            }
            else if (Model.HasCriticalErrors)
            {
                <p class="import-warning">The matrix contains critical errors. Fix the file and upload it again.</p>
            }
        </section>
    }

    @if (Model.ImportedObligations.HasValue)
    {
        <section class="panel">
            <h2>Import result</h2>
            @if (Model.ErrorMessage is null)
            {
                <p>@Model.ImportedObligations.Value tax obligations imported.</p>
            }
            else
            {
                <p class="import-warning">@Model.ErrorMessage</p>
            }
        </section>
    }
</section>
