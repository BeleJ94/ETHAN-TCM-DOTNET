@model AccessUsersViewModel
@{ ViewData["Title"] = "User access"; }
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div><div class="text-uppercase text-primary small fw-bold">Administration · Access management</div><h1 class="h2 d-flex align-items-center gap-2"><svg class="icon icon-lg"><use href="#icon-user"></use></svg>Users</h1><p class="text-muted mb-0">Control application access independently from Active Directory authentication.</p></div>
    <a asp-action="Roles" class="btn btn-outline-primary d-inline-flex align-items-center gap-2"><svg class="icon"><use href="#icon-shield"></use></svg>Roles &amp; permissions</a>
</div>
@if(TempData["StatusMessage"] is string message){<div class="alert alert-@(TempData["StatusType"] ?? "info")">@message</div>}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3"><form method="get" class="row g-2"><div class="col-md-6"><input name="search" value="@Model.Search" class="form-control" placeholder="Search by name, login or email" /></div><div class="col-md-3"><select name="active" class="form-select"><option value="">All statuses</option><option value="true" selected="@(Model.Active == true)">Active</option><option value="false" selected="@(Model.Active == false)">Suspended</option></select></div><div class="col-md-3"><button class="btn btn-dark w-100 d-inline-flex justify-content-center align-items-center gap-2"><svg class="icon"><use href="#icon-search"></use></svg>Search</button></div></form></div>
    <div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>User</th><th>Login</th><th>Roles</th><th>Status</th><th>Last AD sync</th><th></th></tr></thead><tbody>
    @if(Model.Page.Items.Count==0){<tr><td colspan="6" class="text-center py-5 text-muted">No user matches the current filters.</td></tr>}
    @foreach(var user in Model.Page.Items){<tr><td><strong>@user.DisplayName</strong><div class="small text-muted">@user.Email</div></td><td><code>@user.Login</code></td><td><div class="d-flex flex-wrap gap-1">@foreach(var role in user.Roles){<span class="badge text-bg-light border">@role</span>}@if(user.Roles.Count==0){<span class="text-muted">No role</span>}</div></td><td><span class="badge text-bg-@(user.IsActive?"success":"secondary")">@(user.IsActive?"Active":"Suspended")</span></td><td>@(user.LastSyncedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "Never")</td><td class="text-end"><a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"><svg class="icon"><use href="#icon-edit"></use></svg>Manage</a></td></tr>}
    </tbody></table></div>
    <div class="card-footer bg-white d-flex justify-content-between"><span>@Model.Page.TotalCount user(s)</span><div class="d-flex gap-1">@if(Model.Page.Page>1){<a class="btn btn-sm btn-outline-secondary" asp-route-page="@(Model.Page.Page-1)" asp-route-search="@Model.Search" asp-route-active="@Model.Active">Previous</a>}@if(Model.Page.Page<Model.Page.TotalPages){<a class="btn btn-sm btn-outline-secondary" asp-route-page="@(Model.Page.Page+1)" asp-route-search="@Model.Search" asp-route-active="@Model.Active">Next</a>}</div></div>
</div>
