@model AccessRolesViewModel
@{ ViewData["Title"]="Roles and permissions"; }
<div class="d-flex justify-content-between align-items-start mb-4"><div><div class="text-uppercase text-primary small fw-bold">Administration · Access management</div><h1 class="h2 d-flex align-items-center gap-2"><svg class="icon icon-lg"><use href="#icon-shield"></use></svg>Roles &amp; permissions</h1><p class="text-muted">Configure functional permissions independently from Active Directory groups.</p></div><a asp-action="Index" class="btn btn-outline-secondary">Users</a></div>
@if(TempData["StatusMessage"] is string message){<div class="alert alert-@(TempData["StatusType"] ?? "info")">@message</div>}
<div class="accordion" id="roleMatrix">@foreach(var role in Model.Roles){var id="role-"+role.Id.ToString("N");<div class="accordion-item border-0 shadow-sm mb-3"><h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@id"><span><strong>@role.Name</strong><small class="d-block text-muted">@role.Description · @role.Permissions.Count(x=>x.Selected) permissions</small></span></button></h2><div id="@id" class="accordion-collapse collapse" data-bs-parent="#roleMatrix"><div class="accordion-body"><form asp-action="UpdateRole" method="post"><input type="hidden" name="RoleId" value="@role.Id" />@foreach(var domain in role.Permissions.GroupBy(x=>x.Domain)){<h3 class="h6 text-uppercase text-primary border-bottom pb-2 mt-3">@domain.Key</h3><div class="row g-2">@foreach(var permission in domain){<div class="col-md-6"><label class="border rounded p-2 d-flex gap-2 h-100"><input class="form-check-input" type="checkbox" name="PermissionIds" value="@permission.Id" checked="@permission.Selected"/><span><strong class="small">@permission.Name</strong><small class="d-block text-muted">@permission.Description</small></span></label></div>}</div>}<label class="form-label fw-semibold mt-4">Reason for change</label><textarea name="Reason" class="form-control" rows="2" required></textarea><div class="text-end mt-3"><button class="btn btn-primary d-inline-flex align-items-center gap-2"><svg class="icon"><use href="#icon-check"></use></svg>Save @role.Name permissions</button></div></form></div></div></div>}</div>
