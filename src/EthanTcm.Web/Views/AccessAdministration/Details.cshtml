@model AccessUserEditViewModel
@{ ViewData["Title"] = $"Access · {Model.User.DisplayName}"; }
<a asp-action="Index" class="text-decoration-none d-inline-flex align-items-center gap-1 mb-3"><svg class="icon"><use href="#icon-arrow-left"></use></svg>User access</a>
@if(TempData["StatusMessage"] is string message){<div class="alert alert-@(TempData["StatusType"] ?? "info")">@message</div>}
<div class="row g-4"><div class="col-xl-8">
<form asp-action="UpdateUser" method="post" class="card border-0 shadow-sm"><input type="hidden" name="User.Id" value="@Model.User.Id" />
<div class="card-header bg-white"><div class="d-flex align-items-center gap-3"><span class="correspondence-kpi-icon text-primary"><svg class="icon"><use href="#icon-user"></use></svg></span><div><h1 class="h4 mb-0">@Model.User.DisplayName</h1><span class="text-muted">@Model.User.Login · @Model.User.Email</span></div></div></div>
<div class="card-body p-4"><div class="alert alert-info d-flex gap-2"><svg class="icon mt-1"><use href="#icon-shield"></use></svg><div><strong>Identity managed by Active Directory.</strong><br/>Only application access, roles and permissions are managed here.</div></div>
<div class="form-check form-switch mb-4"><input asp-for="IsActive" class="form-check-input" role="switch" /><label asp-for="IsActive" class="form-check-label fw-semibold">Application access active</label></div>
<h2 class="h6 text-uppercase text-muted">Assigned roles</h2><div class="row g-2 mb-4">@foreach(var role in Model.User.Roles){<div class="col-md-6"><label class="border rounded p-3 d-flex gap-2 h-100"><input type="checkbox" name="RoleIds" value="@role.Id" checked="@role.Selected" class="form-check-input"/><span><strong>@role.Name</strong><small class="d-block text-muted">@role.Code</small></span></label></div>}</div>
<label asp-for="Reason" class="form-label fw-semibold">Reason for change</label><textarea asp-for="Reason" class="form-control" rows="3" placeholder="Required for the access audit trail"></textarea><span asp-validation-for="Reason" class="text-danger"></span></div>
<div class="card-footer bg-white text-end"><button class="btn btn-primary d-inline-flex align-items-center gap-2"><svg class="icon"><use href="#icon-check"></use></svg>Save access changes</button></div></form></div>
<div class="col-xl-4"><div class="card border-0 shadow-sm"><div class="card-header bg-white fw-semibold">Effective permissions</div><div class="card-body" style="max-height:38rem;overflow:auto">@foreach(var group in Model.User.EffectivePermissions.GroupBy(x=>x.Split('.')[1])){<div class="small text-uppercase text-muted fw-bold mt-2 mb-1">@group.Key</div>@foreach(var permission in group){<div class="small py-1 d-flex gap-2"><svg class="icon text-success"><use href="#icon-check"></use></svg>@permission.Split('.').Last()</div>}}</div></div></div></div>
