@model CorrespondenceIndexViewModel
@{ ViewData["Title"] = "Correspondence control center"; }
<div class="d-flex justify-content-between align-items-start mb-4">
 <div><div class="text-uppercase text-primary small fw-bold">Correspondence management</div><h1 class="h2 mb-1">Executive control center</h1><p class="text-muted mb-0">Receive, assign, process and dispatch every official communication.</p></div>
 <div class="d-flex gap-2"><a class="btn btn-outline-primary" asp-action="Create" asp-route-direction="Incoming">Register incoming</a><a class="btn btn-primary" asp-action="Create" asp-route-direction="Outgoing">Prepare outgoing</a></div>
</div>
<div class="row g-3 mb-4">
 @foreach(var card in new[]{("Open workload",Model.Dashboard.TotalOpen,"primary"),("Unassigned",Model.Dashboard.Unassigned,"warning"),("Overdue",Model.Dashboard.Overdue,"danger"),("Due in 5 days",Model.Dashboard.DueSoon,"warning"),("Awaiting validation",Model.Dashboard.AwaitingValidation,"info"),("Ready to send",Model.Dashboard.ReadyToSend,"success")}){
 <div class="col-6 col-lg-2"><div class="card h-100 border-0 shadow-sm"><div class="card-body"><div class="small text-muted">@card.Item1</div><div class="display-6 fw-semibold text-@card.Item3">@card.Item2</div></div></div></div> }
</div>
<div class="card border-0 shadow-sm">+ <div class="card-header bg-white py-3"><form class="row g-2 align-items-center" method="get"><div class="col-lg-4"><input class="form-control" name="search" value="@Model.Search" placeholder="Reference, subject or organisation" /></div><div class="col-lg-2"><select class="form-select" name="direction" asp-for="Direction" asp-items="Html.GetEnumSelectList<EthanTcm.Domain.Enums.CorrespondenceDirection>()"><option value="">All directions</option></select></div><div class="col-lg-2"><select class="form-select" name="status" asp-for="Status" asp-items="Html.GetEnumSelectList<EthanTcm.Domain.Enums.CorrespondenceStatus>()"><option value="">All statuses</option></select></div><div class="col-lg-2 form-check ms-2"><input class="form-check-input" type="checkbox" name="myItems" value="true" checked="@Model.MyItems" id="mine"><label for="mine">My portfolio</label></div><div class="col"><button class="btn btn-dark w-100">Apply</button></div></form></div>
 <div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Reference</th><th>Direction</th><th>Subject / counterparty</th><th>Owner</th><th>Due date</th><th>Status</th><th></th></tr></thead><tbody>
 @if(Model.Page.Items.Count==0){<tr><td colspan="7" class="text-center text-muted py-5">No correspondence matches this portfolio.</td></tr>}
 @foreach(var x in Model.Page.Items){<tr class="@(x.IsOverdue?"table-danger":"")"><td><span class="fw-semibold">@x.Reference</span><div class="small text-muted">@x.CorrespondenceDate.ToString("dd MMM yyyy")</div></td><td><span class="badge text-bg-@(x.Direction==EthanTcm.Domain.Enums.CorrespondenceDirection.Incoming?"primary":"dark")">@x.Direction</span></td><td><div class="fw-semibold">@x.Subject</div><div class="small text-muted">@x.Counterparty</div></td><td>@(x.AssignedTo??"Unassigned")</td><td>@(x.DueDate?.ToString("dd MMM yyyy")??"—")</td><td><span class="badge rounded-pill text-bg-light border">@x.Status</span></td><td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@x.Id">Open</a></td></tr>}
 </tbody></table></div>
 <div class="card-footer bg-white d-flex justify-content-between"><span class="text-muted">@Model.Page.TotalCount records</span><div>@if(Model.Page.Page>1){<a class="btn btn-sm btn-outline-secondary" asp-route-page="@(Model.Page.Page-1)" asp-route-search="@Model.Search" asp-route-direction="@Model.Direction" asp-route-status="@Model.Status">Previous</a>} @if(Model.Page.Page<Model.Page.TotalPages){<a class="btn btn-sm btn-outline-secondary" asp-route-page="@(Model.Page.Page+1)" asp-route-search="@Model.Search" asp-route-direction="@Model.Direction" asp-route-status="@Model.Status">Next</a>}</div></div>
</div>
