@model CorrespondenceCreateViewModel
@{ ViewData["Title"] = Model.Direction == EthanTcm.Domain.Enums.CorrespondenceDirection.Incoming ? "Register incoming correspondence" : "Prepare outgoing correspondence"; }
<div class="row justify-content-center"><div class="col-xl-10"><div class="mb-4"><a asp-action="Index" class="text-decoration-none d-inline-flex align-items-center gap-1"><svg class="icon" aria-hidden="true"><use href="#icon-arrow-left"></use></svg>Control center</a><h1 class="h2 mt-2 d-flex align-items-center gap-2"><svg class="icon icon-lg text-primary" aria-hidden="true"><use href="@(Model.Direction == EthanTcm.Domain.Enums.CorrespondenceDirection.Incoming ? "#icon-inbox" : "#icon-send")"></use></svg>@ViewData["Title"]</h1><p class="text-muted">Capture the essential information. The official reference is generated when the record is registered.</p></div>
<form method="post" class="card border-0 shadow-sm"><div class="card-body p-4"><div asp-validation-summary="ModelOnly" class="alert alert-danger"></div><input asp-for="Direction" type="hidden" />
 <div class="row g-3"><div class="col-md-8"><label asp-for="Subject" class="form-label fw-semibold"></label><input asp-for="Subject" class="form-control form-control-lg" /><span asp-validation-for="Subject" class="text-danger"></span></div><div class="col-md-4"><label asp-for="BusinessReference" class="form-label fw-semibold">Business reference</label><input asp-for="BusinessReference" class="form-control form-control-lg" placeholder="e.g. DGI/CTL/2026/184" /></div>
 <div class="col-md-6"><label asp-for="CorrespondentOrganizationId" class="form-label fw-semibold">Correspondent organisation</label><select asp-for="CorrespondentOrganizationId" asp-items="Model.Organizations" class="form-select"><option value="">Select a registered organisation</option></select></div><div class="col-md-6"><label asp-for="InternalDepartmentId" class="form-label fw-semibold">Internal department</label><select asp-for="InternalDepartmentId" asp-items="Model.Departments" class="form-select"><option value="">Select the responsible department</option></select></div>
 <div class="col-md-4"><label asp-for="CorrespondenceDate" class="form-label"></label><input asp-for="CorrespondenceDate" class="form-control" /></div><div class="col-md-4"><label asp-for="Priority" class="form-label"></label><select asp-for="Priority" asp-items="Html.GetEnumSelectList<EthanTcm.Domain.Enums.CorrespondencePriority>()" class="form-select"></select></div><div class="col-md-4"><label asp-for="Channel" class="form-label"></label><select asp-for="Channel" asp-items="Html.GetEnumSelectList<EthanTcm.Domain.Enums.CorrespondenceChannel>()" class="form-select"></select></div>
 <div class="col-md-6"><label class="form-label">Sender contact person</label><input asp-for="SenderName" class="form-control" /></div><div class="col-md-6"><label class="form-label">Recipient contact person</label><input asp-for="RecipientName" class="form-control" /></div>
 <div class="col-md-4"><label asp-for="Confidentiality" class="form-label"></label><select asp-for="Confidentiality" asp-items="Html.GetEnumSelectList<EthanTcm.Domain.Enums.CorrespondenceConfidentiality>()" class="form-select"></select></div><div class="col-md-4"><label class="form-label">Tax declaration ID (optional)</label><input asp-for="TaxDeclarationId" class="form-control" /></div><div class="col-md-4"><label class="form-label">Tax obligation ID (optional)</label><input asp-for="TaxObligationId" class="form-control" /></div>
 <div class="col-12"><label asp-for="Summary" class="form-label"></label><textarea asp-for="Summary" class="form-control" rows="4"></textarea></div></div></div><div class="card-footer bg-white p-4 d-flex justify-content-between align-items-center gap-2"><span class="small text-muted d-flex align-items-center gap-2"><svg class="icon" aria-hidden="true"><use href="#icon-shield"></use></svg>The official tracking number will be generated automatically.</span><div class="d-flex gap-2"><a asp-action="Index" class="btn btn-light d-inline-flex align-items-center gap-2"><svg class="icon" aria-hidden="true"><use href="#icon-x"></use></svg>Cancel</a><button class="btn btn-primary px-4 d-inline-flex align-items-center gap-2"><svg class="icon" aria-hidden="true"><use href="#icon-check"></use></svg>Create correspondence and continue</button></div></div></form></div></div>
