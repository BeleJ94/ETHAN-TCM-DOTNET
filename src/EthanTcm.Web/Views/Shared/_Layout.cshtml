@using Microsoft.AspNetCore.Authorization
@inject ICurrentUserService CurrentUser
@inject IWebHostEnvironment Environment
@inject Microsoft.Extensions.Options.IOptions<EthanTcmAuthenticationOptions> AuthenticationOptions
@inject IAuthorizationService AuthorizationService
@{
    var activeController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var activeAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var activeDashboardView = Context.Request.Query["view"].ToString();
    var canViewTaxDeclarations = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ViewTaxDeclarations)).Succeeded;
    var canGenerateDeclarations = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.GenerateTaxDeclarations)).Succeeded;
    var canCreateDeclarations = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.CreateTaxDeclarations)).Succeeded;
    var canManagePayments = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ManageTaxPayments)).Succeeded;
    var canManageTaxObligations = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ManageTaxObligations)).Succeeded;
    var canImportTaxMatrix = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ImportTaxMatrix)).Succeeded;
    var canViewAuditLogs = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ViewAuditLogs)).Succeeded;
    var canRunAdministrationTasks = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.RunAdministrationTasks)).Succeeded;
    var canViewUserAdministration = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ViewUserAdministration)).Succeeded;
    var canViewCorrespondence = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.ViewCorrespondence)).Succeeded;
    var canCreateCorrespondence = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.CreateCorrespondence)).Succeeded;
    var canAssignCorrespondence = (await AuthorizationService.AuthorizeAsync(User, ApplicationPermissions.AssignCorrespondence)).Succeeded;
    var hasDeclarationsMenu = canViewTaxDeclarations;
    var hasPaymentsMenu = canManagePayments;
    var hasReferentialMenu = canManageTaxObligations || canImportTaxMatrix;
    var hasMonitoringMenu = canViewAuditLogs || canViewTaxDeclarations;
    var hasAdministrationMenu = canRunAdministrationTasks || canViewUserAdministration;
    var isDeclarationsActive = activeController == "TaxDeclarations";
    var isPaymentsActive = activeController == "Payments";
    var isCorrespondenceActive = activeController is "Correspondences" or "CorrespondenceActions" or "CorrespondenceOrganizations";
    var isReferentialActive = activeController is "TaxObligations" or "TaxMatrixImport";
    var isMonitoringActive = activeController == "AuditLogs" || (activeController == "Home" && activeDashboardView is nameof(DashboardView.LateItems) or nameof(DashboardView.ComplianceOverview));
    var isAdministrationActive = activeController is "AdminSeed" or "AccessAdministration";
    var showDevUserSwitcher = Environment.IsDevelopment() && AuthenticationOptions.Value.Mode == AuthMode.LocalAuth;
    var isMonitoringDashboard = activeController == "Home" && activeDashboardView is nameof(DashboardView.LateItems) or nameof(DashboardView.ComplianceOverview);
    var isMainDashboardActive = activeController == "Home" && !isMonitoringDashboard;
    var correspondenceMyItems = Context.Request.Query["myItems"].ToString().Equals("true", StringComparison.OrdinalIgnoreCase);
    var correspondenceMyActions = !Context.Request.Query["myActions"].ToString().Equals("false", StringComparison.OrdinalIgnoreCase);
    var correspondenceDirection = Context.Request.Query["direction"].ToString();
    var currentDevProfile = Context.Request.Cookies.TryGetValue(EthanTcm.Web.Authentication.DevelopmentUserProfiles.CookieName, out var devProfileKey)
        ? devProfileKey
        : "administrator";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ETHAN TCM</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EthanTcm.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <svg class="icon-sprite" aria-hidden="true" focusable="false">
        <symbol id="icon-dashboard" viewBox="0 0 24 24">
            <path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-12h8V3h-8v6Z" />
        </symbol>
        <symbol id="icon-file" viewBox="0 0 24 24">
            <path d="M6 2h8l4 4v16H6V2Z" />
            <path d="M14 2v5h5" />
            <path d="M9 13h6M9 17h6" />
        </symbol>
        <symbol id="icon-database" viewBox="0 0 24 24">
            <ellipse cx="12" cy="5" rx="8" ry="3" />
            <path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5" />
            <path d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" />
        </symbol>
        <symbol id="icon-upload" viewBox="0 0 24 24">
            <path d="M12 16V4" />
            <path d="m7 9 5-5 5 5" />
            <path d="M4 20h16" />
        </symbol>
        <symbol id="icon-shield" viewBox="0 0 24 24">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
            <path d="m9 12 2 2 4-5" />
        </symbol>
        <symbol id="icon-user" viewBox="0 0 24 24">
            <path d="M20 21a8 8 0 0 0-16 0" />
            <circle cx="12" cy="7" r="4" />
        </symbol>
        <symbol id="icon-plus" viewBox="0 0 24 24">
            <path d="M12 5v14M5 12h14" />
        </symbol>
        <symbol id="icon-edit" viewBox="0 0 24 24">
            <path d="M12 20h9" />
            <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z" />
        </symbol>
        <symbol id="icon-open" viewBox="0 0 24 24">
            <path d="M7 17 17 7" />
            <path d="M8 7h9v9" />
            <path d="M5 5v14h14" />
        </symbol>
        <symbol id="icon-download" viewBox="0 0 24 24">
            <path d="M12 3v12" />
            <path d="m7 10 5 5 5-5" />
            <path d="M4 21h16" />
        </symbol>
        <symbol id="icon-trash" viewBox="0 0 24 24">
            <path d="M3 6h18" />
            <path d="M8 6V4h8v2" />
            <path d="M6 6l1 16h10l1-16" />
        </symbol>
        <symbol id="icon-check" viewBox="0 0 24 24">
            <path d="m5 12 4 4L19 6" />
        </symbol>
        <symbol id="icon-x" viewBox="0 0 24 24">
            <path d="M18 6 6 18M6 6l12 12" />
        </symbol>
        <symbol id="icon-clock" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3 2" />
        </symbol>
        <symbol id="icon-calendar" viewBox="0 0 24 24">
            <path d="M7 2v4M17 2v4" />
            <path d="M4 9h16" />
            <path d="M5 5h14v16H5V5Z" />
        </symbol>
        <symbol id="icon-alert" viewBox="0 0 24 24">
            <path d="M12 3 2 21h20L12 3Z" />
            <path d="M12 9v5M12 18h.01" />
        </symbol>
        <symbol id="icon-credit-card" viewBox="0 0 24 24">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 10h18" />
            <path d="M7 15h3" />
        </symbol>
        <symbol id="icon-paperclip" viewBox="0 0 24 24">
            <path d="m21 12-9 9a6 6 0 0 1-8.5-8.5l9-9a4 4 0 0 1 5.7 5.7l-9 9a2 2 0 1 1-2.8-2.8l8.5-8.5" />
        </symbol>
        <symbol id="icon-search" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="7" />
            <path d="m20 20-4-4" />
        </symbol>
        <symbol id="icon-inbox" viewBox="0 0 24 24">
            <path d="M4 4h16v16H4V4Z" />
            <path d="M4 14h5l2 3h2l2-3h5" />
            <path d="M12 4v7M9 8l3 3 3-3" />
        </symbol>
        <symbol id="icon-send" viewBox="0 0 24 24">
            <path d="m3 11 18-8-8 18-2-8-8-2Z" />
            <path d="m11 13 5-5" />
        </symbol>
        <symbol id="icon-filter" viewBox="0 0 24 24">
            <path d="M4 5h16M7 12h10M10 19h4" />
        </symbol>
        <symbol id="icon-building" viewBox="0 0 24 24">
            <path d="M4 21V5l8-3v19M12 8h8v13M2 21h20" />
            <path d="M7 8h2M7 12h2M7 16h2M15 12h2M15 16h2" />
        </symbol>
        <symbol id="icon-list" viewBox="0 0 24 24">
            <path d="M9 6h11M9 12h11M9 18h11" />
            <path d="M4 6h.01M4 12h.01M4 18h.01" />
        </symbol>
        <symbol id="icon-arrow-left" viewBox="0 0 24 24">
            <path d="M19 12H5M11 6l-6 6 6 6" />
        </symbol>
    </svg>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid px-3">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">E</span>
                    <span>
                        <strong>ETHAN TCM</strong>
                        <small>Tax Compliance Management</small>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNavigation" class="navbar-collapse collapse">
                    <ul class="navbar-nav app-top-nav">
                        <li class="nav-item">
                            <a class="nav-link @(isMainDashboardActive ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">
                                <svg class="icon"><use href="#icon-dashboard"></use></svg>
                                Dashboard
                            </a>
                        </li>
                        @if (hasDeclarationsMenu)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isDeclarationsActive ? "active" : string.Empty)" href="#" id="declarationsMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <svg class="icon"><use href="#icon-file"></use></svg>
                                    Declarations
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="declarationsMenu">
                                    <li>
                                        <a class="dropdown-item @(activeController == "TaxDeclarations" && activeAction == "Index" ? "active" : string.Empty)" asp-controller="TaxDeclarations" asp-action="Index">
                                            <svg class="icon"><use href="#icon-file"></use></svg>
                                            All declarations
                                        </a>
                                    </li>
                                    @if (canGenerateDeclarations)
                                    {
                                        <li>
                                            <a class="dropdown-item @(activeController == "TaxDeclarations" && activeAction == "Generate" ? "active" : string.Empty)" asp-controller="TaxDeclarations" asp-action="Generate">
                                                <svg class="icon"><use href="#icon-plus"></use></svg>
                                                Generate declarations
                                            </a>
                                        </li>
                                    }
                                    @if (canCreateDeclarations)
                                    {
                                        <li>
                                            <a class="dropdown-item @(activeController == "TaxDeclarations" && activeAction == "Manual" ? "active" : string.Empty)" asp-controller="TaxDeclarations" asp-action="Manual">
                                                <svg class="icon"><use href="#icon-edit"></use></svg>
                                                Manual declaration
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (hasPaymentsMenu)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isPaymentsActive ? "active" : string.Empty)" href="#" id="paymentsMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <svg class="icon"><use href="#icon-credit-card"></use></svg>
                                    Payments
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="paymentsMenu">
                                    <li>
                                        <a class="dropdown-item @(activeController == "Payments" && activeAction == "Pending" ? "active" : string.Empty)" asp-controller="Payments" asp-action="Pending">
                                            <svg class="icon"><use href="#icon-credit-card"></use></svg>
                                            Payments follow-up
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(activeController == "Payments" && activeAction == "Late" ? "active" : string.Empty)" asp-controller="Payments" asp-action="Late">
                                            <svg class="icon"><use href="#icon-alert"></use></svg>
                                            Late payments
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(activeController == "Payments" && activeAction == "MissingProof" ? "active" : string.Empty)" asp-controller="Payments" asp-action="MissingProof">
                                            <svg class="icon"><use href="#icon-paperclip"></use></svg>
                                            Missing payment proof
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        @if (canViewCorrespondence)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isCorrespondenceActive ? "active" : string.Empty)" href="#" id="correspondenceMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <svg class="icon"><use href="#icon-inbox"></use></svg>
                                    Correspondence
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="correspondenceMenu">
                                    <li><h6 class="dropdown-header">Overview</h6></li>
                                    <li><a class="dropdown-item @(activeController == "Correspondences" && activeAction == "Index" && !correspondenceMyItems ? "active" : string.Empty)" asp-controller="Correspondences" asp-action="Index"><svg class="icon"><use href="#icon-dashboard"></use></svg>Control center</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><h6 class="dropdown-header">My work</h6></li>
                                    <li><a class="dropdown-item @(activeController == "Correspondences" && activeAction == "Index" && correspondenceMyItems ? "active" : string.Empty)" asp-controller="Correspondences" asp-action="Index" asp-route-myItems="true"><svg class="icon"><use href="#icon-user"></use></svg>My portfolio</a></li>
                                    <li><a class="dropdown-item @(activeController == "CorrespondenceActions" && correspondenceMyActions ? "active" : string.Empty)" asp-controller="CorrespondenceActions" asp-action="Index" asp-route-myActions="true"><svg class="icon"><use href="#icon-list"></use></svg>My follow-up actions</a></li>
                                    @if (canCreateCorrespondence)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><h6 class="dropdown-header">New correspondence</h6></li>
                                        <li><a class="dropdown-item @(activeController == "Correspondences" && activeAction == "Create" && correspondenceDirection == nameof(EthanTcm.Domain.Enums.CorrespondenceDirection.Incoming) ? "active" : string.Empty)" asp-controller="Correspondences" asp-action="Create" asp-route-direction="Incoming"><svg class="icon"><use href="#icon-inbox"></use></svg>Register incoming</a></li>
                                        <li><a class="dropdown-item @(activeController == "Correspondences" && activeAction == "Create" && correspondenceDirection == nameof(EthanTcm.Domain.Enums.CorrespondenceDirection.Outgoing) ? "active" : string.Empty)" asp-controller="Correspondences" asp-action="Create" asp-route-direction="Outgoing"><svg class="icon"><use href="#icon-send"></use></svg>Prepare outgoing</a></li>
                                    }
                                    @if (canAssignCorrespondence)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><h6 class="dropdown-header">Configuration</h6></li>
                                        <li><a class="dropdown-item @(activeController == "CorrespondenceOrganizations" ? "active" : string.Empty)" asp-controller="CorrespondenceOrganizations" asp-action="Index"><svg class="icon"><use href="#icon-building"></use></svg>Correspondent organisations</a></li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (hasMonitoringMenu)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isMonitoringActive ? "active" : string.Empty)" href="#" id="monitoringMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <svg class="icon"><use href="#icon-shield"></use></svg>
                                    Monitoring
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="monitoringMenu">
                                    @if (canViewTaxDeclarations)
                                    {
                                        <li>
                                            <a class="dropdown-item @(activeController == "Home" && activeDashboardView == DashboardView.ComplianceOverview.ToString() ? "active" : string.Empty)" asp-controller="Home" asp-action="Index" asp-route-view="@DashboardView.ComplianceOverview">
                                                <svg class="icon"><use href="#icon-check"></use></svg>
                                                Compliance overview
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item @(activeController == "Home" && activeDashboardView == DashboardView.LateItems.ToString() ? "active" : string.Empty)" asp-controller="Home" asp-action="Index" asp-route-view="@DashboardView.LateItems">
                                                <svg class="icon"><use href="#icon-alert"></use></svg>
                                                Late items
                                            </a>
                                        </li>
                                    }
                                    @if (canViewAuditLogs)
                                    {
                                        <li>
                                            <a class="dropdown-item @(activeController == "AuditLogs" ? "active" : string.Empty)" asp-controller="AuditLogs" asp-action="Index">
                                                <svg class="icon"><use href="#icon-shield"></use></svg>
                                                Audit log
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (hasReferentialMenu)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isReferentialActive ? "active" : string.Empty)" href="#" id="referentialMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <svg class="icon"><use href="#icon-database"></use></svg>
                                    Referential
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="referentialMenu">
                                    @if (canManageTaxObligations)
                                    {
                                        <li>
                                            <a class="dropdown-item @(activeController == "TaxObligations" ? "active" : string.Empty)" asp-controller="TaxObligations" asp-action="Index">
                                                <svg class="icon"><use href="#icon-database"></use></svg>
                                                Tax obligations
                                            </a>
                                        </li>
                                    }
                                    @if (canImportTaxMatrix)
                                    {
                                        <li>
                                            <a class="dropdown-item @(activeController == "TaxMatrixImport" ? "active" : string.Empty)" asp-controller="TaxMatrixImport" asp-action="Index">
                                                <svg class="icon"><use href="#icon-upload"></use></svg>
                                                Import matrix
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (hasAdministrationMenu)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isAdministrationActive ? "active" : string.Empty)" href="#" id="administrationMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <svg class="icon"><use href="#icon-user"></use></svg>
                                    Administration
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="administrationMenu">
                                    @if (canViewUserAdministration)
                                    {
                                        <li><h6 class="dropdown-header">Access management</h6></li>
                                        <li><a class="dropdown-item @(activeController == "AccessAdministration" && activeAction is "Index" or "Details" ? "active" : string.Empty)" asp-controller="AccessAdministration" asp-action="Index"><svg class="icon"><use href="#icon-user"></use></svg>Users</a></li>
                                        <li><a class="dropdown-item @(activeController == "AccessAdministration" && activeAction == "Roles" ? "active" : string.Empty)" asp-controller="AccessAdministration" asp-action="Roles"><svg class="icon"><use href="#icon-shield"></use></svg>Roles &amp; permissions</a></li>
                                    }
                                    @if (canRunAdministrationTasks)
                                    {
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><h6 class="dropdown-header">System</h6></li>
                                    <li>
                                        <a class="dropdown-item @(activeController == "AdminSeed" ? "active" : string.Empty)" asp-controller="AdminSeed" asp-action="Index">
                                            <svg class="icon"><use href="#icon-user"></use></svg>
                                            Admin seed
                                        </a>
                                    </li>
                                    }
                                </ul>
                            </li>
                        }
                    </ul>
                    <div class="app-userbar">
                        @if (showDevUserSwitcher)
                        {
                            <form class="dev-user-switcher" method="post" asp-controller="DevUsers" asp-action="Switch">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                <label class="dev-user-label" for="dev-user-profile">Dev user</label>
                                <select id="dev-user-profile" class="form-select form-select-sm" name="profileKey" onchange="this.form.submit()">
                                    @foreach (var profile in EthanTcm.Web.Authentication.DevelopmentUserProfiles.All)
                                    {
                                        if (profile.Key.Equals(currentDevProfile, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <option value="@profile.Key" selected>@profile.DisplayName</option>
                                        }
                                        else
                                        {
                                            <option value="@profile.Key">@profile.DisplayName</option>
                                        }
                                    }
                                </select>
                            </form>
                        }
                        <a class="profile-link @(activeController == "Account" ? "active" : string.Empty)" asp-area="" asp-controller="Account" asp-action="Profile">
                            <svg class="icon"><use href="#icon-user"></use></svg>
                            Profile
                        </a>
                        <div class="user-chip">
                            <span>@(CurrentUser.DisplayName ?? CurrentUser.Login)</span>
                            <strong>@(CurrentUser.Roles.FirstOrDefault() ?? "No role")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div>
            &copy; 2026 - ETHAN TCM
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
