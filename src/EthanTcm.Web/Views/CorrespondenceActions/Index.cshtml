@model CorrespondenceActionsViewModel
@using EthanTcm.Domain.Enums
@{ViewData["Title"]="Correspondence follow-up actions";}
<div class="d-flex justify-content-between mb-4"><div><div class="text-uppercase text-primary small fw-bold">Proactive monitoring</div><h1 class="h2 d-flex align-items-center gap-2"><svg class="icon icon-lg text-primary" aria-hidden="true"><use href="#icon-list"></use></svg>@(Model.MyActions?"My follow-up actions":"Team follow-up actions")</h1><p class="text-muted">Prioritised work queue across all correspondence.</p></div><a asp-controller="Correspondences" asp-action="Index" class="btn btn-outline-secondary align-self-start d-inline-flex align-items-center gap-2"><svg class="icon" aria-hidden="true"><use href="#icon-file"></use></svg>Correspondence register</a></div>
<div class="row g-3 mb-4">@foreach(var k in new[]{("Open",Model.Dashboard.Open,"primary","icon-list"),("Overdue",Model.Dashboard.Overdue,"danger","icon-alert"),("Due today",Model.Dashboard.DueToday,"warning","icon-calendar"),("Due in 5 days",Model.Dashboard.DueSoon,"info","icon-clock"),("Waiting",Model.Dashboard.Waiting,"secondary","icon-clock"),("Escalated",Model.Dashboard.Escalated,"danger","icon-alert")}){<div class="col"><div class="card border-0 shadow-sm"><div class="card-body"><div class="d-flex justify-content-between align-items-center"><div class="small text-muted">@k.Item1</div><svg class="icon text-@k.Item3" aria-hidden="true"><use href="#@k.Item4"></use></svg></div><div class="display-6 text-@k.Item3">@k.Item2</div></div></div></div>}</div>
<div class="card border-0 shadow-sm"><div class="card-header bg-white"><form class="d-flex gap-2"><select name="status" asp-for="Status" asp-items="Html.GetEnumSelectList<CorrespondenceActionStatus>()" class="form-select"><option value="">All statuses</option></select><select name="myActions" class="form-select"><option value="true">My actions</option><option value="false">Team actions</option></select><button class="btn btn-dark d-inline-flex align-items-center gap-2"><svg class="icon" aria-hidden="true"><use href="#icon-filter"></use></svg>Apply</button></form></div><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Priority</th><th>Action</th><th>Correspondence</th><th>Owner</th><th>Due</th><th>Status</th></tr></thead><tbody>@if(Model.Items.Count==0){<tr><td colspan="6" class="text-center text-muted py-5"><svg class="icon icon-lg mb-2" aria-hidden="true"><use href="#icon-check"></use></svg><div>No follow-up actions in this view.</div></td></tr>}@foreach(var a in Model.Items){<tr class="@(a.IsOverdue?"table-danger":a.IsDueSoon?"table-warning":"")"><td>@a.Priority</td><td><strong>@a.Title</strong></td><td><a asp-controller="Correspondences" asp-action="Details" asp-route-id="@a.CorrespondenceId" class="d-inline-flex align-items-center gap-1"><svg class="icon" aria-hidden="true"><use href="#icon-open"></use></svg>@a.CorrespondenceReference</a><div class="small text-muted">@a.CorrespondenceSubject</div></td><td><span class="d-inline-flex align-items-center gap-1"><svg class="icon text-muted" aria-hidden="true"><use href="#icon-user"></use></svg>@a.AssignedTo</span></td><td><span class="d-inline-flex align-items-center gap-1"><svg class="icon text-muted" aria-hidden="true"><use href="#icon-calendar"></use></svg>@a.DueDate.ToString("dd MMM yyyy")</span></td><td><span class="badge text-bg-light border">@a.Status</span></td></tr>}</tbody></table></div></div>
