@model CorrespondenceOrganizationViewModel
@{ ViewData["Title"]="Correspondent organisations"; }
<div class="d-flex justify-content-between align-items-start mb-4"><div><div class="text-uppercase text-primary small fw-bold">Correspondence referential</div><h1 class="h2">Correspondent organisations</h1><p class="text-muted">Maintain the approved organisations available in incoming and outgoing correspondence.</p></div><a asp-controller="Correspondences" asp-action="Index" class="btn btn-light">Control center</a></div>
<div class="row g-4"><div class="col-lg-8"><div class="card border-0 shadow-sm"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Code</th><th>Organisation</th><th>Contact</th><th>Address</th></tr></thead><tbody>@if(Model.Items.Count==0){<tr><td colspan="4" class="text-center text-muted py-5">No organisation registered yet.</td></tr>}@foreach(var x in Model.Items){<tr><td><span class="badge text-bg-light border">@x.Code</span></td><td class="fw-semibold">@x.Name</td><td>@(x.ContactEmail??"—")</td><td>@(x.Address??"—")</td></tr>}</tbody></table></div></div></div>
<div class="col-lg-4"><form asp-action="Save" method="post" class="card border-0 shadow-sm"><div class="card-header bg-white fw-semibold">Add organisation</div><div class="card-body"><div asp-validation-summary="ModelOnly" class="text-danger"></div><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control mb-3" placeholder="e.g. DGI"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control mb-3"><label asp-for="ContactEmail" class="form-label"></label><input asp-for="ContactEmail" class="form-control mb-3"><label asp-for="Address" class="form-label"></label><textarea asp-for="Address" class="form-control mb-3"></textarea><button class="btn btn-primary w-100">Save organisation</button></div></form></div></div>
